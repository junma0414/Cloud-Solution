{
   "version": 2,
    "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": { 
        "maxLambdaSize": "15mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/grc",
      "dest": "/api/grc/index.py",
      "methods": ["POST","OPTIONS"]
    }
  ]
}
{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
        {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.10",
        "includeFiles": "api/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    }
  ]
}

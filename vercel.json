{
   "version": 2,
    "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/grc.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.10",
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/grc",
      "dest": "/api/grc.py",
      "methods": ["POST", "OPTIONS"]
    }
  ]
}

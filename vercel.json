{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": { "runtime": "python-3.9" }
    }
  ],
  "routes": [
    {
      "src": "/api/grc",
      "dest": "api/index.py"
    }
  ]
}

{
   "version": 2,
    "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/grc.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.10",
        "suppressStream": true
      }
    }
  ],
  "routes": [
    {
      "src": "/api/grc/?$",  // Strict termination with $
      "dest": "/api/grc.py",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/(.*)",
      "status": 404,
      "dest": "/404"
    }
  ]
}
